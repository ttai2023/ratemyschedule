{
  "manifest_version": 3,
  "name": "Rate My Schedule Extension",
  "version": "1.0",
  "description": "DiamondHacks 2026 - Rate My Schedule!",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icon.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://act.ucsd.edu/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://act.ucsd.edu/*"],
      "js": ["ucsd-content.js"],
      "run_at": "document_idle"
    }
  ]
}
